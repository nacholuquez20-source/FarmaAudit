# COPÍA ESTE ARCHIVO A .env Y COMPLETÁ CON TUS VALORES REALES
# NUNCA commitees .env con credenciales reales

# Anthropic API
ANTHROPIC_API_KEY=sk-ant-xxx

# OpenAI API (Whisper)
OPENAI_API_KEY=sk-proj-xxx

# WAHA (WhatsApp)
WAHA_URL=https://waha-production-0227.up.railway.app
WAHA_API_KEY=auditbot123
WAHA_SESSION=default

# Google Sheets
GOOGLE_SHEETS_ID=xxx
# Base64-encoded Google Service Account JSON
# Obtené con: cat service-account.json | base64 (o PowerShell equivalent)
GOOGLE_SERVICE_ACCOUNT_JSON=xxx

# Google Drive
GOOGLE_DRIVE_FOLDER_ID=xxx

# FastAPI
HOST=0.0.0.0
PORT=8000
DEBUG=false

# Coordinator notifications
COORDINADOR_TEL=549XXXXXXXXX
